{
  "expo": {
    "name": "Stackr",
    "slug": "Stackr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "Stackr",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
  [
    "expo-splash-screen",
    {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff",
      "imageWidth": 400
    }
  ]
],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tommo86.Stackr",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.tommo86.Stackr"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2e729a1c-5747-4209-a7df-0f6fc69410dc"
      }
    }
  }
}